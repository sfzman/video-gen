# Server
VIDEO_GEN_SERVER_NAME=127.0.0.1
VIDEO_GEN_SERVER_PORT=7860

# Optional runtime directories
VIDEO_GEN_OUTPUT_DIR=./outputs
VIDEO_GEN_TASK_QUEUE_DIR=./task_queue

# Native source repositories
ANISORA_REPO_ROOT=/path/to/Index-anisora/anisoraV3.2
LTX_PIPELINES_SRC=/path/to/LTX-2/packages/ltx-pipelines/src
LTX_CORE_SRC=/path/to/LTX-2/packages/ltx-core/src

# Anisora checkpoints
ANISORA_CKPT_DIR=/path/to/Index-anisora-V3.2
ANISORA_LOW_SUBDIR=low_noise_model
ANISORA_HIGH_SUBDIR=high_noise_model

# LTX checkpoints
LTX_CHECKPOINT_PATH=/path/to/ltx23_full_model.safetensors
LTX_GEMMA_ROOT=/path/to/gemma_root
LTX_DISTILLED_LORA_PATH=/path/to/ltx23_distilled_lora.safetensors
LTX_SPATIAL_UPSAMPLER_PATH=/path/to/ltx23_spatial_upsampler.safetensors
